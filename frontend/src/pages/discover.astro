---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getMovieGenres, getTVGenres, getAiringTodayTV, getOnTheAirTV, getTrendingMovies, getTrendingTV, getTrendingPeople } from '../lib/api';

type SectionState = { data: any[]; error: boolean };
const state: Record<string, SectionState> = {};
function mk() { return { data: [], error: false }; }

const loaders: Record<string, () => Promise<any[]>> = {
  movieGenres: getMovieGenres,
  tvGenres: getTVGenres,
  airingToday: getAiringTodayTV,
  onTheAir: getOnTheAirTV,
  trendingMovies: getTrendingMovies,
  trendingTV: getTrendingTV,
  trendingPeople: getTrendingPeople,
};
for (const k of Object.keys(loaders)) state[k] = mk();

await Promise.all(Object.entries(loaders).map(async ([k, fn]) => {
  try { state[k].data = await fn(); } catch { state[k].error = true; }
}));

const anyError = Object.values(state).some((s: any) => s.error);

const mediaSections = [
  { key: 'airingToday', title: 'Airing Today', type: 'tv' },
  { key: 'onTheAir', title: 'On The Air', type: 'tv' },
  { key: 'trendingMovies', title: 'Trending Movies', type: 'movie' },
  { key: 'trendingTV', title: 'Trending TV', type: 'tv' },
  { key: 'trendingPeople', title: 'Trending People', type: 'person' },
] as const;
---
<BaseLayout title="Discover">
  <div class="container">
    <h1 class="page-title">Discover</h1>
    {anyError && <div class="error-msg">Some content failed to load. <a href="/discover">Retry</a></div>}

    {state.movieGenres.data.length > 0 && (
      <div>
        <h2 class="section-title">Movie Genres</h2>
        <div class="genre-grid">
          {state.movieGenres.data.map((g) => (
            <a href={'/search?q=' + g.name} class="genre-card">{g.name}</a>
          ))}
        </div>
      </div>
    )}
    {state.movieGenres.error && (
      <div class="error-msg">Failed to load movie genres. <a href="/discover">Retry</a></div>
    )}

    {state.tvGenres.data.length > 0 && (
      <div>
        <h2 class="section-title">TV Genres</h2>
        <div class="genre-grid">
          {state.tvGenres.data.map((g) => (
            <a href={'/search?q=' + g.name} class="genre-card">{g.name}</a>
          ))}
        </div>
      </div>
    )}
    {state.tvGenres.error && (
      <div class="error-msg">Failed to load TV genres. <a href="/discover">Retry</a></div>
    )}

    {mediaSections.map((section) => {
      const s = state[section.key];
      return (
        <div>
          <h2 class="section-title">{section.title}</h2>
          {s.error ? (
            <div class="error-msg">Failed to load {section.title.toLowerCase()}. <a href="/discover">Retry</a></div>
          ) : s.data.length > 0 ? (
            <div class="grid grid-6">
              {s.data.slice(0, 6).map((m) => (
                <a href={'/' + section.type + '/' + m.id} class="card">
                  <div class="poster-wrap">
                    {m.poster ? (
                      <img src={m.poster} alt={m.title} loading="lazy" />
                    ) : (
                      <div class="poster-ph">{section.type === 'tv' ? '—' : section.type === 'person' ? '—' : '—'}</div>
                    )}
                    {m.rating > 0 && (
                      <div class="card-rating"> {(m.rating / 10).toFixed(1)}</div>
                    )}
                  </div>
                  <div class="card-info">
                    <h3>{m.title}</h3>
                    {m.year && <span class="card-year">{m.year}</span>}
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <span class="empty-icon">{section.type === 'tv' ? '—' : section.type === 'person' ? '—' : '—'}</span>
              <p>No {section.title.toLowerCase()} available right now.</p>
              <p class="empty-hint">Try again later or browse a different category.</p>
            </div>
          )}
        </div>
      );
    })}
  </div>
</BaseLayout>

<style>
  .page-title { font-size: 36px; font-weight: 800; padding: 40px 0 0; }
  .section-title { font-size: 20px; font-weight: 700; margin: 40px 0 16px; }
  .genre-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .genre-card { padding: 10px 20px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 14px; font-weight: 500; transition: all 0.2s; }
  .genre-card:hover { background: var(--accent); border-color: var(--accent); color: white; }
</style>
