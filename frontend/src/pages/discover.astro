---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import FilterPanel from '@/components/discover/FilterPanel.svelte';
import PosterGrid from '@/components/media/PosterGrid.astro';
import Pagination from '@/components/ui/Pagination.svelte';
import Skeleton from '@/components/ui/Skeleton.astro';
import { api, ApiError } from '@/lib/api/client';
import type { Movie, TvShow, Paged } from '@/lib/api/types';

const params = Astro.url.searchParams;
const type = (params.get('type') as 'movie' | 'tv') || 'movie';
const page = Math.max(1, parseInt(params.get('page') || '1'));

// Collect all filter params except type/page
const filterKeys = ['sort_by', 'with_genres', 'vote_average.gte', 'with_original_language',
  'primary_release_date.gte', 'primary_release_date.lte', 'first_air_date.gte', 'first_air_date.lte'];
const filters: Record<string, string> = {};
for (const key of filterKeys) {
  const val = params.get(key);
  if (val) filters[key] = val;
}
filters['page'] = String(page);

// Default sort
if (!filters['sort_by']) filters['sort_by'] = 'popularity.desc';

let genres: { id: number; name: string }[] = [];
try {
  const g = await api.genres(type);
  genres = g.genres ?? [];
} catch { /* ignore genre load failure */ }

let data: Paged<Movie | TvShow> | null = null;
let errorMsg = '';
try {
  data = type === 'tv'
    ? await api.discoverTv(filters) as Paged<Movie | TvShow>
    : await api.discoverMovie(filters) as Paged<Movie | TvShow>;
} catch (e) {
  errorMsg = e instanceof ApiError ? e.message : 'Failed to load results';
}

// Build search params for pagination (exclude page)
const paginationParams: Record<string, string> = { type, ...filters };
delete paginationParams['page'];
---
<DefaultLayout title="Hexen — Discover" description="Discover movies and TV shows by genre, year, rating, and more.">
  <div class="container-content py-8">
    <h1 class="text-3xl font-extrabold">Discover</h1>
    <p class="mt-1 text-ink-secondary">Filter movies and TV shows</p>

    <div class="mt-6 grid grid-cols-1 gap-6 lg:grid-cols-[280px_1fr]">
      <div>
        <FilterPanel
          client:load
          type={type}
          genres={genres}
          initialFilters={filters}
        />
      </div>

      <div>
        {errorMsg ? (
          <div class="rounded-lg border border-red-500/30 bg-red-500/10 p-6 text-center">
            <p class="text-red-400">{errorMsg}</p>
          </div>
        ) : data ? (
          <>
            <div class="mb-4 flex items-center justify-between">
              <p class="text-sm text-ink-secondary">
                {data.total_results.toLocaleString()} results
              </p>
            </div>
            {data.results.length > 0 ? (
              <PosterGrid items={data.results} type={type} />
            ) : (
              <div class="py-16 text-center">
                <p class="text-ink-secondary">No results match your filters.</p>
                <p class="mt-1 text-sm text-ink-secondary">Try adjusting the filters on the left.</p>
              </div>
            )}
            <Pagination
              client:visible
              page={data.page}
              totalPages={Math.min(data.total_pages, 500)}
              basePath="/discover"
              searchParams={paginationParams}
            />
          </>
        ) : (
          <Skeleton count={18} />
        )}
      </div>
    </div>
  </div>
</DefaultLayout>
