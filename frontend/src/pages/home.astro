---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPopularMovies, getTopRatedMovies, getNowPlayingMovies, getUpcomingMovies, getPopularTV, getTopRatedTV } from '../lib/api';

const sections = [
  { key: 'popular', title: 'Popular Movies', link: '/browse?type=movie' },
  { key: 'topRated', title: 'Top Rated', link: '/browse?type=movie' },
  { key: 'nowPlaying', title: 'Now Playing', link: '/browse?type=movie' },
  { key: 'popularTV', title: 'Popular TV Shows', link: '/browse?type=tv' },
] as const;

const state: Record<string, { data: any[]; error: boolean }> = {
  popular: { data: [], error: false },
  topRated: { data: [], error: false },
  nowPlaying: { data: [], error: false },
  popularTV: { data: [], error: false },
};

async function loadSection(key: string, fn: () => Promise<any[]>) {
  try { state[key].data = await fn(); } catch { state[key].error = true; }
}

await Promise.all([
  loadSection('popular', getPopularMovies),
  loadSection('topRated', getTopRatedMovies),
  loadSection('nowPlaying', getNowPlayingMovies),
  loadSection('popularTV', getPopularTV),
]);

const hero = state.popular.data[0];
---
<BaseLayout title="Home">
  {/* Hero Banner */}
  {hero && (
    <section class="hero-section">
      <div class="hero-backdrop" style={`background-image: url(${hero.backdrop || hero.poster || ''})`}></div>
      <div class="hero-gradient"></div>
      <div class="hero-content container">
        <div class="hero-text">
          <span class="hero-badge">Featured</span>
          <h1 class="hero-title">{hero.title}</h1>
          <p class="hero-overview">{hero.overview?.slice(0, 220)}{hero.overview?.length > 220 ? '...' : ''}</p>
          <div class="hero-meta">
            {hero.rating > 0 && <span class="badge badge-gold">{(hero.rating / 10).toFixed(1)}</span>}
            {hero.year && <span class="badge">{hero.year}</span>}
          </div>
          <div class="hero-actions">
            <a href={`/details/${hero.id}?type=movie`} class="btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              Watch Now
            </a>
            <a href={`/details/${hero.id}?type=movie`} class="btn-secondary">More Info</a>
          </div>
        </div>
        <div class="hero-poster">
          {hero.poster ? (
            <img src={hero.poster} alt={hero.title} loading="lazy" />
          ) : (
            <div class="poster-placeholder">—</div>
          )}
        </div>
      </div>
    </section>
  )}

  {/* Quick Filters */}
  <div class="chips-bar">
    <div class="container">
      <div class="chips">
        <a href="/home" class="chip active">All</a>
        <a href="/browse?type=movie" class="chip">Movies</a>
        <a href="/browse?type=tv" class="chip">TV Shows</a>
        <a href="/watch" class="chip">Stream</a>
        <a href="/favorites" class="chip">Favorites</a>
        <a href="/search" class="chip">Search</a>
      </div>
    </div>
  </div>

  {/* Content Sections */}
  <div class="container home-content">
    {sections.map((section) => {
      const s = state[section.key];
      const items = s.data;
      const isTV = section.key === 'popularTV';
      return (
        <section class="content-section">
          <div class="section-header">
            <h2>{section.title}</h2>
            {section.link && <a href={section.link} class="see-all">See all →</a>}
          </div>
          {s.error ? (
            <div class="error-msg">Failed to load {section.title.toLowerCase()}.</div>
          ) : items.length > 0 ? (
            <div class="yt-grid">
              {items.slice(0, 12).map((m: any) => (
                <a href={`/details/${m.id}?type=${isTV ? 'tv' : 'movie'}`} class="yt-card">
                  <div class="yt-thumb">
                    {m.poster ? <img src={m.poster} alt={m.title} loading="lazy" /> : <div class="yt-thumb-ph">—</div>}
                    {m.rating > 0 && <span class="yt-rating-badge">{(m.rating / 10).toFixed(1)}</span>}
                  </div>
                  <div class="yt-info">
                    <div class="yt-meta">
                      <div class="yt-title">{m.title}</div>
                      <div class="yt-stats">
                        {m.year && <span>{m.year}</span>}
                        {m.rating > 0 && <span class="yt-rating-badge">{(m.rating / 10).toFixed(1)}</span>}
                      </div>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="empty-state">
              <p>No {section.title.toLowerCase()} available right now.</p>
            </div>
          )}
        </section>
      );
    })}
  </div>
</BaseLayout>

<style>
  .hero-section {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: center;
    overflow: hidden;
    margin-top: calc(var(--nav-height) * -1);
    padding-top: var(--nav-height);
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: blur(30px) brightness(0.2);
    transform: scale(1.1);
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.7) 60%, transparent 100%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: center;
    padding: 60px 0 80px;
  }

  .hero-text {
    max-width: 600px;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(255, 45, 85, 0.15);
    border-radius: var(--radius-xl);
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 20px;
    letter-spacing: 0.5px;
  }

  .hero-title {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .hero-overview {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 20px;
    max-width: 500px;
  }

  .hero-meta {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hero-poster {
    width: 220px;
    aspect-ratio: 2/3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    flex-shrink: 0;
  }

  .hero-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .poster-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
    background: var(--bg-card);
  }

  .chips-bar {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: var(--nav-height);
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
    z-index: 80;
  }

  .home-content { padding: 20px 24px 50px; }

  .content-section { margin-bottom: 40px; }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      padding: 40px 0 60px;
    }

    .hero-poster { display: none; }

    .hero-title { font-size: 36px; }
  }

  @media (max-width: 768px) {
    .hero-section {
      min-height: 400px;
    }

    .hero-title { font-size: 28px; }

    .hero-actions { flex-direction: column; }

    .home-content { padding: 10px 12px 40px; }
  }
</style>