---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { api, ApiError } from '@/lib/api/client';
import { backdropUrl, posterUrl } from '@/lib/utils/image';
import { formatRating } from '@/lib/utils/format';
import type { SearchResult } from '@/lib/api/types';

let trending: SearchResult[] = [];
let popularMovies: SearchResult[] = [];
let popularTv: SearchResult[] = [];
let nowPlaying: SearchResult[] = [];
let onAir: SearchResult[] = [];
let hero: SearchResult | null = null;
let errors: string[] = [];

async function safe<T>(label: string, fn: () => Promise<T>): Promise<T | null> {
  try { return await fn(); } catch (e) { errors.push(`${label}: ${e instanceof ApiError ? e.message : 'failed'}`); return null; }
}

const [tr, pm, pt, np, oa] = await Promise.all([
  safe('Trending', () => api.trending('all', 'day')),
  safe('Popular Movies', () => api.movieList('popular', 1)),
  safe('Popular TV', () => api.tvList('popular', 1)),
  safe('Now Playing', () => api.movieList('now_playing', 1)),
  safe('On The Air', () => api.tvList('on_the_air', 1)),
]);

if (tr?.results) trending = tr.results.filter(r => r.backdrop_path);
if (pm?.results) popularMovies = pm.results as unknown as SearchResult[];
if (pt?.results) popularTv = pt.results as unknown as SearchResult[];
if (np?.results) nowPlaying = np.results as unknown as SearchResult[];
if (oa?.results) onAir = oa.results as unknown as SearchResult[];
hero = trending[0] ?? null;

function hrefFor(item: SearchResult): string {
  return item.media_type === 'tv' ? `/tv/${item.id}` : `/movies/${item.id}`;
}
function titleFor(item: SearchResult): string {
  return item.title ?? item.name ?? 'Untitled';
}
---
<DefaultLayout title="Hexen — Home">
  {hero && backdropUrl(hero.backdrop_path, 'w1280') ? (
    <section class="relative h-[60vh] min-h-[420px] w-full overflow-hidden">
      <img src={backdropUrl(hero.backdrop_path, 'w1280')!} alt="" class="absolute inset-0 h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-base via-base/50 to-transparent"></div>
      <div class="container-content relative flex h-full items-end pb-10">
        <div class="max-w-2xl">
          <span class="chip chip-active">🔥 Trending Today</span>
          <h1 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">{titleFor(hero)}</h1>
          {hero.overview && <p class="mt-3 max-w-xl text-base text-ink-secondary line-clamp-2">{hero.overview}</p>}
          <div class="mt-5 flex gap-3">
            <a href={hrefFor(hero)} class="btn-primary">View Details</a>
            <a href="/discover" class="btn-ghost">Browse</a>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="container-content py-16 text-center">
      <p class="text-ink-secondary">{errors.length > 0 ? 'Backend unreachable. Is backend_server.py running?' : 'Loading…'}</p>
      {errors.length > 0 && <p class="mt-2 text-xs text-ink-secondary">{errors[0]}</p>}
    </section>
  )}

  <div class="container-content space-y-12 py-10">
    {nowPlaying.length > 0 && (
      <section>
        <h2 class="mb-3 text-xl font-bold">🎬 Now Playing in Theaters</h2>
        <div class="poster-grid">
          {nowPlaying.slice(0, 12).map((item) => (
            <a href={hrefFor(item)} class="group block overflow-hidden rounded-lg bg-base-surface shadow-md transition-transform hover:scale-105">
              <div class="relative aspect-[2/3] overflow-hidden bg-base-elevated">
                {posterUrl(item.poster_path, 'w342') && (
                  <img src={posterUrl(item.poster_path, 'w342')!} alt={titleFor(item)} class="h-full w-full object-cover" loading="lazy" />
                )}
                {item.vote_average > 0 && (
                  <span class="absolute bottom-2 left-2 rounded bg-black/80 px-1.5 py-0.5 text-xs font-semibold text-yellow-400">★ {formatRating(item.vote_average)}</span>
                )}
              </div>
              <div class="p-2.5"><p class="truncate text-sm font-medium">{titleFor(item)}</p></div>
            </a>
          ))}
        </div>
      </section>
    )}

    {popularMovies.length > 0 && (
      <section>
        <div class="mb-3 flex items-center justify-between">
          <h2 class="text-xl font-bold">Popular Movies</h2>
          <a href="/movies" class="text-sm text-accent hover:underline">See all →</a>
        </div>
        <div class="poster-grid">
          {popularMovies.slice(0, 12).map((item) => (
            <a href={`/movies/${item.id}`} class="group block overflow-hidden rounded-lg bg-base-surface shadow-md transition-transform hover:scale-105">
              <div class="relative aspect-[2/3] overflow-hidden bg-base-elevated">
                {posterUrl(item.poster_path, 'w342') && (
                  <img src={posterUrl(item.poster_path, 'w342')!} alt={item.title ?? ''} class="h-full w-full object-cover" loading="lazy" />
                )}
                {item.vote_average > 0 && (
                  <span class="absolute bottom-2 left-2 rounded bg-black/80 px-1.5 py-0.5 text-xs font-semibold text-yellow-400">★ {formatRating(item.vote_average)}</span>
                )}
              </div>
              <div class="p-2.5"><p class="truncate text-sm font-medium">{item.title}</p></div>
            </a>
          ))}
        </div>
      </section>
    )}

    {popularTv.length > 0 && (
      <section>
        <div class="mb-3 flex items-center justify-between">
          <h2 class="text-xl font-bold">Popular TV Shows</h2>
          <a href="/tv" class="text-sm text-accent hover:underline">See all →</a>
        </div>
        <div class="poster-grid">
          {popularTv.slice(0, 12).map((item: any) => (
            <a href={`/tv/${item.id}`} class="group block overflow-hidden rounded-lg bg-base-surface shadow-md transition-transform hover:scale-105">
              <div class="relative aspect-[2/3] overflow-hidden bg-base-elevated">
                {posterUrl(item.poster_path, 'w342') && (
                  <img src={posterUrl(item.poster_path, 'w342')!} alt={item.name ?? ''} class="h-full w-full object-cover" loading="lazy" />
                )}
                {item.vote_average > 0 && (
                  <span class="absolute bottom-2 left-2 rounded bg-black/80 px-1.5 py-0.5 text-xs font-semibold text-yellow-400">★ {formatRating(item.vote_average)}</span>
                )}
              </div>
              <div class="p-2.5"><p class="truncate text-sm font-medium">{item.name}</p></div>
            </a>
          ))}
        </div>
      </section>
    )}

    {onAir.length > 0 && (
      <section>
        <h2 class="mb-3 text-xl font-bold">📺 On The Air</h2>
        <div class="poster-grid">
          {onAir.slice(0, 12).map((item: any) => (
            <a href={`/tv/${item.id}`} class="group block overflow-hidden rounded-lg bg-base-surface shadow-md transition-transform hover:scale-105">
              <div class="relative aspect-[2/3] overflow-hidden bg-base-elevated">
                {posterUrl(item.poster_path, 'w342') && (
                  <img src={posterUrl(item.poster_path, 'w342')!} alt={item.name ?? ''} class="h-full w-full object-cover" loading="lazy" />
                )}
                {item.vote_average > 0 && (
                  <span class="absolute bottom-2 left-2 rounded bg-black/80 px-1.5 py-0.5 text-xs font-semibold text-yellow-400">★ {formatRating(item.vote_average)}</span>
                )}
              </div>
              <div class="p-2.5"><p class="truncate text-sm font-medium">{item.name}</p></div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</DefaultLayout>
