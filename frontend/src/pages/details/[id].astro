---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FavoriteButton from '../../components/FavoriteButton.svelte';
import { getMovieDetails, getTVDetails } from '../../lib/api';

const { id } = Astro.params;
const type = Astro.url.searchParams.get('type') || 'movie';
const mediaType = type === 'tv' ? 'tv' : 'movie';

let item: any = null;
let error = false;

try {
  if (mediaType === 'tv') {
    item = await getTVDetails(Number(id));
  } else {
    item = await getMovieDetails(Number(id));
  }
} catch {
  error = true;
}

const isTV = item?.media_type === 'tv';
const backLink = isTV ? '/browse?type=tv' : '/browse?type=movie';
const watchUrl = `/watch?q=${encodeURIComponent(item?.title || '')}&type=${mediaType}`;
---
<BaseLayout title={item?.title || 'Not Found'} description={item?.overview} image={item?.poster}>
  {error || !item ? (
    <div class="error-page">
      <h2>404</h2>
      <p>Content not found.</p>
      <a href="/browse" class="btn-primary">Browse Content</a>
    </div>
  ) : (
    <>
      <div class="detail-backdrop" style={`background-image: url(${item.backdrop || item.poster})`}></div>
      <div class="detail-backdrop-gradient"></div>

      <div class="container detail-layout">
        {/* ─── Main Column ─────────────────────────── */}
        <div class="detail-main">
          {/* Backdrop / Poster */}
          <div class="detail-hero">
            {item.backdrop ? (
              <img src={item.backdrop} alt={item.title} class="detail-backdrop-img" />
            ) : item.poster ? (
              <img src={item.poster} alt={item.title} class="detail-backdrop-img" />
            ) : (
              <div class="detail-backdrop-ph">—</div>
            )}
            <a href={watchUrl} class="play-overlay">
              <svg width="68" height="48" viewBox="0 0 68 48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="rgba(0,0,0,0.7)"/><path d="M 45,24 27,14 27,34" fill="white"/></svg>
            </a>
          </div>

          {/* Title + Meta */}
          <div class="detail-info">
            <h1>{item.title}</h1>
            {item.tagline && <p class="tagline">"{item.tagline}"</p>}
            <div class="meta-row">
              {item.rating > 0 && <span class="badge badge-gold">{(item.rating / 10).toFixed(1)}</span>}
              {item.year && <span class="badge">{item.year}</span>}
              {item.status && <span class="badge">{item.status}</span>}
              {item.runtime > 0 && <span class="badge">{Math.floor(item.runtime / 60)}h {item.runtime % 60}m</span>}
              {isTV && item.number_of_seasons > 0 && <span class="badge">{item.number_of_seasons} Season{item.number_of_seasons !== 1 ? 's' : ''}</span>}
              {item.imdb_id && <a href={`https://imdb.com/title/${item.imdb_id}`} target="_blank" rel="noopener" class="badge badge-accent">IMDb</a>}
            </div>
            <div class="action-row">
              <a href={watchUrl} class="btn-primary">Stream Now</a>
              <FavoriteButton id={item.id} title={item.title} poster={item.poster} year={item.year} media_type={mediaType} client:load />
            </div>
            <p class="overview">{item.overview}</p>
          </div>

          {/* Genres */}
          {item.genres.length > 0 && (
            <div class="detail-section">
              <h2>Genres</h2>
              <div class="tags">
                {item.genres.map((g: string) => <span class="tag">{g}</span>)}
              </div>
            </div>
          )}

          {/* Budget/Revenue for movies */}
          {!isTV && item.budget > 0 && (
            <div class="detail-section">
              <h2>Details</h2>
              <div class="stats">
                <div class="stat"><span class="label">Budget</span><span>${(item.budget / 1_000_000).toFixed(1)}M</span></div>
                <div class="stat"><span class="label">Revenue</span><span>${(item.revenue / 1_000_000).toFixed(1)}M</span></div>
              </div>
            </div>
          )}

          {/* Videos */}
          {item.videos.length > 0 && (
            <div class="detail-section">
              <h2>Videos</h2>
              <div class="video-grid">
                {item.videos.slice(0, 3).map((v: any) => (
                  <div class="video-card">
                    <iframe src={`https://www.youtube.com/embed/${v.key}`} title={v.name} allowfullscreen loading="lazy"></iframe>
                    <p class="video-name">{v.name}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Cast */}
          {item.cast.length > 0 && (
            <div class="detail-section">
              <h2>Cast</h2>
              <div class="cast-grid">
                {item.cast.slice(0, 8).map((c: any) => (
                  <a href={`/person/${c.id}`} class="cast-card">
                    {c.profile ? <img src={c.profile} alt={c.name} class="cast-img" loading="lazy" /> : <div class="cast-ph">—</div>}
                    <p class="cast-name">{c.name}</p>
                    <p class="cast-char">{c.character}</p>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Where to Watch */}
          {item.watch_providers && Object.keys(item.watch_providers).length > 0 && (
            <div class="detail-section">
              <h2>Where to Watch</h2>
              {Object.entries(item.watch_providers).slice(0, 2).map(([region, providers]: [string, any]) => (
                <div class="providers">
                  <span class="provider-region">{region}</span>
                  <div class="provider-list">
                    {providers.map((p: any) => <span class="provider-badge">{p.provider_name}</span>)}
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* Reviews */}
          {item.reviews.length > 0 && (
            <div class="detail-section">
              <h2>Reviews</h2>
              {item.reviews.slice(0, 3).map((r: any) => (
                <div class="review-card">
                  <div class="review-header">
                    <strong>{r.author}</strong>
                    {r.rating && <span class="badge badge-gold">{r.rating}/10</span>}
                  </div>
                  <p>{r.content.slice(0, 200)}{r.content.length > 200 ? '...' : ''}</p>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* ─── Sidebar ─────────────────────────────── */}
        <div class="detail-sidebar">
          {item.similar.length > 0 && (
            <div class="sidebar-section">
              <h3>Similar</h3>
              {item.similar.slice(0, 6).map((m: any) => (
                <a href={`/details/${m.id}?type=${m.media_type || mediaType}`} class="sidebar-card">
                  <div class="sidebar-thumb">
                    {m.poster ? <img src={m.poster} alt={m.title} loading="lazy" /> : <div class="mini-ph">—</div>}
                  </div>
                  <div class="sidebar-meta">
                    <p class="sidebar-title">{m.title}</p>
                    {m.year && <span class="sidebar-year">{m.year}</span>}
                  </div>
                </a>
              ))}
            </div>
          )}

          {item.recommendations.length > 0 && (
            <div class="sidebar-section">
              <h3>Recommended</h3>
              {item.recommendations.slice(0, 6).map((m: any) => (
                <a href={`/details/${m.id}?type=${m.media_type || mediaType}`} class="sidebar-card">
                  <div class="sidebar-thumb">
                    {m.poster ? <img src={m.poster} alt={m.title} loading="lazy" /> : <div class="mini-ph">—</div>}
                  </div>
                  <div class="sidebar-meta">
                    <p class="sidebar-title">{m.title}</p>
                    {m.year && <span class="sidebar-year">{m.year}</span>}
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </>
  )}
</BaseLayout>

<style>
  .detail-hero {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
    margin-bottom: 24px;
  }
  .detail-backdrop-img { width: 100%; height: 100%; object-fit: cover; }
  .detail-backdrop-ph {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 60px;
    opacity: 0.2;
  }
  .play-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .detail-hero:hover .play-overlay { opacity: 1; }

  .detail-info { margin-bottom: 24px; }
  .detail-info h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.02em; }
  .tagline { font-style: italic; color: var(--text-secondary); margin-bottom: 12px; font-size: 15px; }
  .meta-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
  .action-row { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .overview { font-size: 15px; line-height: 1.6; color: var(--text-secondary); }

  .stats { display: flex; gap: 32px; }
  .stat .label { display: block; font-size: 12px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; }
  .stat span:last-child { font-size: 17px; font-weight: 600; }

  .sidebar-section { margin-bottom: 24px; }
  .sidebar-section h3 { font-size: 16px; font-weight: 600; margin-bottom: 12px; }
  .sidebar-card { display: flex; gap: 10px; margin-bottom: 8px; padding: 4px; border-radius: var(--radius-sm); transition: background 0.2s; }
  .sidebar-card:hover { background: var(--bg-hover); }
  .sidebar-thumb { width: 168px; height: 94px; border-radius: var(--radius-sm); overflow: hidden; flex-shrink: 0; background: var(--bg-card); }
  .sidebar-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .sidebar-meta { padding: 4px 0; min-width: 0; }
  .sidebar-title { font-size: 13px; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.3; }
  .sidebar-year { font-size: 12px; color: var(--text-secondary); }

  .mini-ph { width: 100%; aspect-ratio: 2/3; background: var(--bg-card); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; font-size: 20px; }

  @media (max-width: 1024px) {
    .detail-layout { grid-template-columns: 1fr; }
    .detail-sidebar { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
  }
  @media (max-width: 600px) {
    .detail-hero { border-radius: 0; margin: 0 -12px; width: calc(100% + 24px); }
    .detail-info h1 { font-size: 24px; }
  }
</style>