---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import StreamSourcePicker from '@/components/player/StreamSourcePicker.svelte';
import { api, ApiError } from '@/lib/api/client';
import type { TvShow } from '@/lib/api/types';
import { backdropUrl, posterUrl } from '@/lib/utils/image';
import { formatRating, formatDate } from '@/lib/utils/format';

const { id } = Astro.params;
if (!id || isNaN(Number(id))) {
  return Astro.redirect('/404');
}

const params = Astro.url.searchParams;
const initialSeason = parseInt(params.get('season') || '1');
const initialEpisode = parseInt(params.get('episode') || '1');

let show: TvShow | null = null;
let errorMsg = '';
try {
  show = await api.tv(Number(id));
} catch (e) {
  errorMsg = e instanceof ApiError ? e.message : 'Failed to load TV show';
}

const backdrop = show ? backdropUrl(show.backdrop_path, 'w1280') : null;
const poster = show ? posterUrl(show.poster_path, 'w342') : null;
---
<DefaultLayout title={show ? `Watch ${show.name} — Hexen` : 'Watch — Hexen'}>
  {errorMsg ? (
    <div class="container-content py-16 text-center">
      <p class="text-red-400">{errorMsg}</p>
      <a href="/tv" class="mt-4 inline-block btn-ghost">← Back to TV Shows</a>
    </div>
  ) : show ? (
    <div class="container-content py-8">
      <a href={`/tv/${show.id}`} class="inline-flex items-center gap-1 text-sm text-ink-secondary hover:text-ink-primary">
        ← Back to {show.name}
      </a>

      <div class="mt-4 grid grid-cols-1 gap-6 lg:grid-cols-[1fr_360px]">
        <div>
          <h1 class="text-2xl font-bold">{show.name}</h1>
          <div class="mt-1 flex flex-wrap items-center gap-3 text-sm text-ink-secondary">
            {show.vote_average > 0 && <span class="text-yellow-400">★ {formatRating(show.vote_average)}</span>}
            {show.first_air_date && <span>{formatDate(show.first_air_date)}</span>}
            {show.number_of_seasons && <span>{show.number_of_seasons} seasons</span>}
          </div>

          <StreamSourcePicker
            client:load
            query={show.name}
            isTv={true}
            initialSeason={initialSeason}
            initialEpisode={initialEpisode}
          />
        </div>

        <aside class="space-y-4">
          <div class="card-surface p-4">
            <div class="flex gap-4">
              {poster ? (
                <img src={poster} alt={show.name} class="w-24 rounded-lg shadow-md" />
              ) : null}
              <div class="flex-1">
                {show.tagline && <p class="italic text-ink-secondary text-sm">{show.tagline}</p>}
                {show.overview && <p class="mt-2 text-sm text-ink-secondary line-clamp-5">{show.overview}</p>}
              </div>
            </div>
            {show.genres && show.genres.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {show.genres.map(g => <span class="chip text-xs">{g.name}</span>)}
              </div>
            )}
          </div>

          <div class="card-surface p-4">
            <h3 class="mb-2 font-bold">Need a specific episode?</h3>
            <p class="text-sm text-ink-secondary">
              Use the Season and Episode fields above to find the right stream.
              The title is searched on Moviebox automatically.
            </p>
          </div>
        </aside>
      </div>
    </div>
  ) : null}
</DefaultLayout>
