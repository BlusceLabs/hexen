---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import HeroBanner from '@/components/streaming/HeroBanner.astro';
import ContentCarousel from '@/components/streaming/ContentCarousel.svelte';
import { api } from '@/lib/api/client';
import type { SearchResult } from '@/lib/api/types';

let featured: SearchResult | null = null;
let trending: SearchResult[] = [];
let popularMovies: SearchResult[] = [];
let popularTV: SearchResult[] = [];
let topRated: SearchResult[] = [];

try {
  // Fetch trending for hero banner
  const trendingRes = await api.trending('all', 'day');
  trending = trendingRes.results.filter((r) => r.backdrop_path);
  featured = trending[0] || null;

  // Fetch popular movies
  const moviesRes = await api.movies.popular(1);
  popularMovies = moviesRes.results.slice(0, 20);

  // Fetch popular TV shows
  const tvRes = await api.tv.popular(1);
  popularTV = tvRes.results.slice(0, 20);

  // Fetch top rated
  const topRatedRes = await api.movies.topRated(1);
  topRated = topRatedRes.results.slice(0, 20);
} catch (error) {
  console.error('Error fetching content:', error);
}
---

<DefaultLayout title="Hexen — Stream Movies & TV Shows">
  <!-- Hero Banner -->
  {#if featured}
    <HeroBanner featured={featured} />
  {/if}

  <!-- Content Sections -->
  <div class="space-y-8 pb-12">
    {#if trending.length > 1}
      <ContentCarousel 
        title="Trending Now" 
        items={trending.slice(1, 21)}
        href="/discover?sort=popularity.desc"
        client:load
      />
    {/if}

    {#if popularMovies.length > 0}
      <ContentCarousel 
        title="Popular Movies" 
        items={popularMovies}
        href="/movies"
        client:load
      />
    {/if}

    {#if popularTV.length > 0}
      <ContentCarousel 
        title="Popular TV Shows" 
        items={popularTV}
        href="/tv"
        client:load
      />
    {/if}

    {#if topRated.length > 0}
      <ContentCarousel 
        title="Top Rated" 
        items={topRated}
        href="/movies?sort=vote_average.desc"
        client:load
      />
    {/if}
  </div>

  <!-- Browse by Genre Section -->
  <section class="container-content py-12">
    <h2 class="mb-6 text-2xl font-bold">Browse by Genre</h2>
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {[
        { name: 'Action', id: 28, emoji: '💥' },
        { name: 'Comedy', id: 35, emoji: '😂' },
        { name: 'Drama', id: 18, emoji: '🎭' },
        { name: 'Horror', id: 27, emoji: '👻' },
        { name: 'Sci-Fi', id: 878, emoji: '🚀' },
        { name: 'Romance', id: 10749, emoji: '💕' },
        { name: 'Thriller', id: 53, emoji: '🔪' },
        { name: 'Animation', id: 16, emoji: '🎨' },
        { name: 'Documentary', id: 99, emoji: '📽️' },
        { name: 'Fantasy', id: 14, emoji: '🧙' }
      ].map((genre) => (
        <a
          href={`/discover?with_genres=${genre.id}`}
          class="group relative overflow-hidden rounded-xl border border-base-border bg-gradient-to-br from-base-surface to-base-elevated p-6 text-center shadow-lg transition-all hover:scale-105 hover:border-accent hover:shadow-2xl focus:outline-none focus:ring-2 focus:ring-accent"
        >
          <div class="mb-2 text-4xl">{genre.emoji}</div>
          <h3 class="font-semibold text-ink-primary group-hover:text-accent transition-colors">
            {genre.name}
          </h3>
        </a>
      ))}
    </div>
  </section>
</DefaultLayout>
