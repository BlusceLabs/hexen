---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { api } from '@/lib/api/client';
import type { SearchResult } from '@/lib/api/types';
import { backdropUrl } from '@/lib/utils/image';

let trending: SearchResult[] = [];
let heroError = false;
try {
  const res = await api.trending('all', 'day');
  trending = res.results.filter((r) => r.backdrop_path).slice(0, 6);
} catch {
  heroError = true;
}

const hero = trending[0];
const rails = trending.slice(1);

function hrefFor(item: SearchResult): string {
  return item.media_type === 'tv' ? `/tv/${item.id}` : `/movies/${item.id}`;
}
function titleFor(item: SearchResult): string {
  return item.title ?? item.name ?? 'Untitled';
}
---
<DefaultLayout title="Hexen — Stream Movies & TV">
  <section class="relative h-[70vh] min-h-[480px] w-full overflow-hidden">
    {hero && backdropUrl(hero.backdrop_path, 'w1280') ? (
      <>
        <img
          src={backdropUrl(hero.backdrop_path, 'w1280')!}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-base via-base/60 to-base/20"></div>
        <div class="container-content relative flex h-full items-end pb-12">
          <div class="max-w-2xl">
            <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
              {titleFor(hero)}
            </h1>
            {hero.overview && (
              <p class="mt-3 max-w-xl text-base text-ink-secondary line-clamp-3">{hero.overview}</p>
            )}
            <div class="mt-6 flex gap-3">
              <a href={hrefFor(hero)} class="btn-primary">View Details</a>
              <a href="/discover" class="btn-ghost">Browse</a>
            </div>
          </div>
        </div>
      </>
    ) : (
      <div class="flex h-full items-center justify-center">
        <p class="text-ink-secondary">
          {heroError
            ? `Could not reach backend at ${import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:8000'}`
            : 'Loading…'}
        </p>
      </div>
    )}
  </section>

  <div class="container-content py-12">
    <h2 class="text-2xl font-bold">Welcome to Hexen</h2>
    <p class="mt-2 text-ink-secondary">Movies, TV shows, and streaming — powered by TMDB and Moviebox.</p>

    <div class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
      <a href="/movies" class="card-surface p-6 hover:border-accent transition-colors">
        <h3 class="font-semibold">🎬 Movies</h3>
        <p class="mt-1 text-sm text-ink-secondary">Popular, top rated, now playing</p>
      </a>
      <a href="/tv" class="card-surface p-6 hover:border-accent transition-colors">
        <h3 class="font-semibold">📺 TV Shows</h3>
        <p class="mt-1 text-sm text-ink-secondary">Airing today, on the air, top rated</p>
      </a>
      <a href="/discover" class="card-surface p-6 hover:border-accent transition-colors">
        <h3 class="font-semibold">🔍 Discover</h3>
        <p class="mt-1 text-sm text-ink-secondary">Filter by genre, year, rating</p>
      </a>
      <a href="/search" class="card-surface p-6 hover:border-accent transition-colors">
        <h3 class="font-semibold">⭐ Search</h3>
        <p class="mt-1 text-sm text-ink-secondary">Find anything</p>
      </a>
    </div>

    {rails.length > 0 && (
      <>
        <h2 class="mt-12 text-2xl font-bold">Trending Today</h2>
        <div class="poster-grid mt-4">
          {rails.map((item) => (
            <a href={hrefFor(item)} class="card-surface overflow-hidden hover:scale-105 transition-transform duration-200">
              <div class="aspect-[2/3] bg-base-elevated">
                {backdropUrl(item.backdrop_path, 'w300') && (
                  <img src={backdropUrl(item.backdrop_path, 'w300')!} alt={titleFor(item)} class="h-full w-full object-cover" loading="lazy" />
                )}
              </div>
              <div class="p-3">
                <p class="truncate text-sm font-medium">{titleFor(item)}</p>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</DefaultLayout>
