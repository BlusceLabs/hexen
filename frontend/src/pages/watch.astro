---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Watch">
  <div class="watch-page">
    {/* ─── Search Section ──────────────────────── */}
    <div class="watch-hero">
      <h1>Stream Movies & TV Shows</h1>
      <p class="subtitle">Search for any movie or TV show to start streaming</p>

      <div class="search-form">
        <input type="text" id="search-input" placeholder="Search for a movie or TV show..." autocomplete="off" />
        <button id="search-btn" type="button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
        </button>
      </div>

      <div class="chips" style="justify-content:center">
        <button class="chip active" data-type="movie">— Movie</button>
        <button class="chip" data-type="tv">— TV Show</button>
      </div>

      <div id="tv-opts" class="tv-opts" style="display:none">
        <label>Season <input type="number" id="season-input" value="1" min="1" max="50" /></label>
        <label>Episode <input type="number" id="episode-input" value="1" min="1" max="99" /></label>
      </div>
    </div>

    {/* ─── Results ─────────────────────────────── */}
    <div id="results" class="results container"></div>

    {/* ─── Player ──────────────────────────────── */}
    <div id="player-section" class="player-section container" style="display:none">
      <div class="player-layout">
        <div class="player-main">
          <div class="video-wrapper">
            <video id="video-player" controls autoplay></video>
          </div>
          <div class="player-info">
            <h2 id="player-title"></h2>
            <div id="quality-selector" class="quality-selector"></div>
          </div>
        </div>
        <div class="player-sidebar">
          <button id="back-btn" class="back-btn">← Back to search</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const API = 'http://localhost:8000';
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchBtn = document.getElementById('search-btn') as HTMLButtonElement;
    const resultsDiv = document.getElementById('results')!;
    const playerSection = document.getElementById('player-section')!;
    const playerTitle = document.getElementById('player-title')!;
    const videoPlayer = document.getElementById('video-player') as HTMLVideoElement;
    const qualitySelector = document.getElementById('quality-selector')!;
    const backBtn = document.getElementById('back-btn')!;
    const typeBtns = document.querySelectorAll('.chip[data-type]');
    const tvOpts = document.getElementById('tv-opts')!;
    const seasonInput = document.getElementById('season-input') as HTMLInputElement;
    const episodeInput = document.getElementById('episode-input') as HTMLInputElement;

    let searchType = 'movie';

    typeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        typeBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        searchType = btn.getAttribute('data-type') || 'movie';
        tvOpts.style.display = searchType === 'tv' ? 'flex' : 'none';
      });
    });

    function formatSize(bytes: number): string {
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
      if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(0) + ' MB';
      return (bytes / (1024 * 1024 * 1024)).toFixed(1) + ' GB';
    }

    function showPlayer(data: any) {
      resultsDiv.style.display = 'none';
      playerSection.style.display = 'block';

      playerTitle.textContent = data.title + (data.season ? ` S${data.season}E${data.episode}` : '');

      const bestUrl = data.downloads[0]?.url;
      if (bestUrl) {
        videoPlayer.src = `${API}/proxy?url=${encodeURIComponent(bestUrl)}`;
        videoPlayer.load();
      }

      qualitySelector.innerHTML = data.downloads.map((d: any, i: number) =>
        `<button class="chip ${i === 0 ? 'active' : ''}" data-url="${d.url}">
          ${d.resolution}p <span style="opacity:0.6;font-size:11px">(${formatSize(d.size)})</span>
        </button>`
      ).join('');

      qualitySelector.querySelectorAll('.chip').forEach((btn: Element) => {
        btn.addEventListener('click', () => {
          qualitySelector.querySelectorAll('.chip').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const url = btn.getAttribute('data-url');
          const currentTime = videoPlayer.currentTime;
          videoPlayer.src = `${API}/proxy?url=${encodeURIComponent(url!)}`;
          videoPlayer.load();
          videoPlayer.currentTime = currentTime;
          videoPlayer.play();
        });
      });
    }

    async function searchContent() {
      const query = searchInput.value.trim();
      if (!query) return;

      resultsDiv.innerHTML = '<div class="loading"><div class="spinner"></div><p>Searching Moviebox...</p></div>';
      playerSection.style.display = 'none';
      resultsDiv.style.display = 'block';

      try {
        let endpoint;
        if (searchType === 'tv') {
          const season = seasonInput.value || '1';
          const episode = episodeInput.value || '1';
          endpoint = `${API}/stream/tv?q=${encodeURIComponent(query)}&season=${season}&episode=${episode}`;
        } else {
          endpoint = `${API}/stream/info?q=${encodeURIComponent(query)}`;
        }

        const resp = await fetch(endpoint);
        const data = await resp.json();

        if (data.downloads && data.downloads.length > 0) {
          showPlayer(data);
        } else if (data.subject_id) {
          resultsDiv.innerHTML = `
            <div class="result-card">
              <h3>${data.title}</h3>
              <p style="color:var(--text-secondary);font-size:14px">
                ${data.has_resource ? '✅ Stream available' : '❌ No stream available'}
                ${data.limited ? ' (Limited)' : ''}
              </p>
              ${data.error ? `<p style="color:var(--accent);font-size:13px;margin-top:4px">${data.error}</p>` : ''}
              ${searchType === 'tv' && !data.has_resource ? '<p style="color:var(--text-secondary);font-size:13px;margin-top:8px">Try adjusting the season/episode numbers, or this content may not be available.</p>' : ''}
            </div>`;
        } else {
          resultsDiv.innerHTML = '<div class="empty-state"><span class="empty-icon">[ ]</span><p>No results found. Try a different search term.</p></div>';
        }
      } catch (err: any) {
        resultsDiv.innerHTML = `<div class="empty-state"><span class="empty-icon">[!]</span><p>Connection error: ${err.message}</p></div>`;
      }
    }

    searchBtn.addEventListener('click', searchContent);
    searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') searchContent(); });

    backBtn.addEventListener('click', () => {
      playerSection.style.display = 'none';
      resultsDiv.style.display = 'block';
      videoPlayer.pause();
      videoPlayer.src = '';
    });

    // Auto-search from URL params
    const urlParams = new URLSearchParams(window.location.search);
    const prefillQuery = urlParams.get('q');
    const prefillType = urlParams.get('type');
    if (prefillQuery) {
      searchInput.value = prefillQuery;
      if (prefillType === 'tv') {
        typeBtns.forEach(b => b.classList.remove('active'));
        document.querySelector('[data-type="tv"]')?.classList.add('active');
        searchType = 'tv';
        tvOpts.style.display = 'flex';
      }
      searchContent();
    }
  </script>
</BaseLayout>

<style>
  .watch-page { min-height: 80vh; }

  .watch-hero {
    text-align: center;
    padding: 48px 24px 32px;
    border-bottom: 1px solid var(--border);
  }
  .watch-hero h1 { font-size: 32px; font-weight: 600; margin-bottom: 8px; }
  .subtitle { font-size: 14px; color: var(--text-secondary); margin-bottom: 24px; }

  .search-form {
    display: flex;
    max-width: 560px;
    margin: 0 auto 16px;
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .search-form:focus-within { border-color: #3ea6ff; }
  .search-form input {
    flex: 1;
    background: var(--bg-primary);
    border: none;
    outline: none;
    color: var(--text-primary);
    padding: 10px 16px;
    font-size: 14px;
    font-family: inherit;
  }
  .search-form input::placeholder { color: var(--text-secondary); }
  .search-form button {
    background: var(--bg-card);
    border: none;
    border-left: 1px solid var(--border);
    color: var(--text-primary);
    padding: 0 16px;
    display: flex;
    align-items: center;
    cursor: pointer;
    transition: background 0.2s;
  }
  .search-form button:hover { background: var(--bg-hover); }

  .tv-opts {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 12px;
  }
  .tv-opts label {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-secondary);
    font-size: 13px;
  }
  .tv-opts input {
    width: 56px;
    padding: 6px 10px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-primary);
    font-size: 13px;
    text-align: center;
    font-family: inherit;
  }
  .tv-opts input:focus { outline: none; border-color: #3ea6ff; }

  .results { padding: 24px; }

  .loading { text-align: center; padding: 48px 0; }
  .spinner { width: 32px; height: 32px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 12px; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .result-card {
    max-width: 600px;
    margin: 0 auto;
    padding: 20px;
    background: var(--bg-card);
    border-radius: var(--radius);
  }
  .result-card h3 { font-size: 18px; font-weight: 500; margin-bottom: 8px; }

  .player-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 24px;
    padding: 16px 24px;
  }
  .player-main { min-width: 0; }
  .video-wrapper {
    width: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    background: #000;
  }
  video { width: 100%; aspect-ratio: 16/9; display: block; }

  .player-info { margin-top: 12px; }
  .player-info h2 { font-size: 18px; font-weight: 500; margin-bottom: 10px; }

  .quality-selector { display: flex; gap: 6px; flex-wrap: wrap; }

  .player-sidebar { min-width: 0; }
  .back-btn {
    padding: 8px 16px;
    background: var(--bg-chip);
    border: none;
    border-radius: 20px;
    color: var(--text-primary);
    font-size: 13px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s;
  }
  .back-btn:hover { background: var(--bg-hover); }

  .empty-state { text-align: center; padding: 60px 24px; }
  .empty-icon { font-size: 48px; display: block; margin-bottom: 12px; opacity: 0.3; }
  .empty-state p { color: var(--text-secondary); font-size: 14px; }

  @media (max-width: 768px) {
    .watch-hero h1 { font-size: 24px; }
    .player-layout { grid-template-columns: 1fr; padding: 12px; }
    .player-sidebar { display: none; }
  }
</style>
