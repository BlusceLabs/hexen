---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FavoriteButton from '../../components/FavoriteButton.svelte';
import { getTVDetails } from '../../lib/api';

const { id } = Astro.params;
let show: any = null;
let error = false;

try {
  show = await getTVDetails(Number(id));
} catch {
  error = true;
}
---
<BaseLayout title={show?.title || 'TV Show Not Found'} description={show?.overview} image={show?.poster}>
  {error ? (
    <div class="error-page">
      <h2>404</h2>
      <p>TV show not found. It may have been removed or the ID is invalid.</p>
      <a href="/tv" class="btn-primary">Browse TV Shows →</a>
    </div>
  ) : show && (
    <div class="detail-backdrop" style={`background-image: url(${show.backdrop || show.poster})`}></div>
    <div class="detail-backdrop-gradient"></div>

    <div class="container detail-layout">
      <div class="poster-col">
        <div class="poster-wrap">
          {show.poster ? <img src={show.poster} alt={show.title} class="detail-poster" /> : <div class="detail-poster-ph">—</div>}
          <FavoriteButton id={show.id} title={show.title} poster={show.poster} year={show.year} media_type="tv" client:load />
        </div>
      </div>
      <div class="info-col">
        <h1>{show.title} <span class="year">({show.year})</span></h1>
        {show.tagline && <p class="tagline">"{show.tagline}"</p>}
        <div class="meta-row">
          {show.rating > 0 && <span class="badge badge-gold"> {(show.rating / 10).toFixed(1)}</span>}
          {show.genres.map((g: string) => <span class="badge">{g}</span>)}
          {show.status && <span class="badge">{show.status}</span>}
        </div>
        <p class="overview">{show.overview}</p>

        {show.videos.length > 0 && (
          <div class="detail-section">
            <h2>Videos ({show.videos.length})</h2>
            <div class="video-grid">
              {show.videos.slice(0, 4).map((v: any) => (
                <div class="video-card">
                  <iframe src={`https://www.youtube.com/embed/${v.key}`} title={v.name} allowfullscreen loading="lazy"></iframe>
                  <p class="video-name">{v.name} <span class="badge">{v.type}</span></p>
                </div>
              ))}
            </div>
          </div>
        )}

        {show.cast.length > 0 && (
          <div class="detail-section">
            <h2>Cast ({show.cast.length})</h2>
            <div class="cast-grid">
              {show.cast.slice(0, 12).map((c: any) => (
                <a href={`/person/${c.id}`} class="cast-card">
                  {c.profile ? <img src={c.profile} alt={c.name} class="cast-img" loading="lazy" /> : <div class="cast-ph">—</div>}
                  <p class="cast-name">{c.name}</p>
                  <p class="cast-char">{c.character}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        {show.watch_providers && Object.keys(show.watch_providers).length > 0 && (
          <div class="detail-section">
            <h2>Where to Watch</h2>
            {Object.entries(show.watch_providers).slice(0, 3).map(([region, providers]: [string, any]) => (
              <div class="providers">
                <span class="provider-region">{region}</span>
                <div class="provider-list">
                  {providers.map((p: any) => <span class="provider-badge"><img src={p.logo_url} alt={p.provider_name} class="provider-logo" loading="lazy" />{p.provider_name}</span>)}
                </div>
              </div>
            ))}
          </div>
        )}

        {show.keywords.length > 0 && (
          <div class="detail-section">
            <h2>Keywords</h2>
            <div class="tags">
              {show.keywords.map((k: string) => <span class="tag">{k}</span>)}
            </div>
          </div>
        )}

        {show.reviews.length > 0 && (
          <div class="detail-section">
            <h2>Reviews ({show.reviews.length})</h2>
            {show.reviews.slice(0, 5).map((r: any) => (
              <div class="review-card">
                <div class="review-header">
                  <strong>{r.author}</strong>
                  {r.rating && <span class="badge badge-gold"> {r.rating}/10</span>}
                </div>
                <p>{r.content.slice(0, 300)}{r.content.length > 300 ? '...' : ''}</p>
              </div>
            ))}
          </div>
        )}

        {show.logos.length > 0 && (
          <div class="detail-section">
            <h2>Title Logos ({show.logos.length})</h2>
            <div class="logos">
              {show.logos.map((l: any) => <img src={l.url} alt={show.title + ' logo'} class="logo-img" />)}
            </div>
          </div>
        )}

        {show.translations.length > 0 && (
          <div class="detail-section">
            <h2>Translations ({show.translations.length})</h2>
            <div class="tags">
              {show.translations.map((t: any) => <span class="tag">{t.english_name}</span>)}
            </div>
          </div>
        )}

        {show.similar.length > 0 && (
          <div class="detail-section">
            <h2>Similar Shows</h2>
            <div class="similar-grid">
              {show.similar.slice(0, 6).map((s: any) => (
                <a href={`/tv/${s.id}`} class="mini-card">
                  {s.poster ? <img src={s.poster} alt={s.title} loading="lazy" /> : <div class="mini-ph">—</div>}
                  <p>{s.title}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        {show.recommendations.length > 0 && (
          <div class="detail-section">
            <h2>Recommended</h2>
            <div class="similar-grid">
              {show.recommendations.slice(0, 6).map((s: any) => (
                <a href={`/tv/${s.id}`} class="mini-card">
                  {s.poster ? <img src={s.poster} alt={s.title} loading="lazy" /> : <div class="mini-ph">—</div>}
                  <p>{s.title}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  )}
</BaseLayout>

<style>
  h1 { font-size: 36px; font-weight: 800; }
  .year { color: var(--text-secondary); font-weight: 400; }
  .tagline { font-style: italic; color: var(--text-secondary); margin: 8px 0 16px; }
  .meta-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .overview { font-size: 16px; line-height: 1.7; color: var(--text-secondary); margin-bottom: 24px; }
</style>
