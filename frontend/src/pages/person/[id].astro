---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import PosterCard from '@/components/media/PosterCard.astro';
import { api, ApiError } from '@/lib/api/client';
import type { Person, PersonMovieCredit, PersonTvCredit } from '@/lib/api/types';
import { profileUrl } from '@/lib/utils/image';
import { formatDate } from '@/lib/utils/format';

const { id } = Astro.params;
if (!id || isNaN(Number(id))) {
  return Astro.redirect('/404');
}

let person: Person | null = null;
let movieCredits: PersonMovieCredit[] = [];
let tvCredits: PersonTvCredit[] = [];
let errorMsg = '';

try {
  const [p, mc, tc] = await Promise.all([
    api.person(Number(id)),
    api.personMovieCredits(Number(id)).then(r => r.movies ?? []).catch(() => []),
    api.personTvCredits(Number(id)).then(r => r.tv ?? []).catch(() => []),
  ]);
  person = p; movieCredits = mc; tvCredits = tc;
} catch (e) {
  errorMsg = e instanceof ApiError ? e.message : 'Failed to load person';
}

const profile = person ? profileUrl(person.profile_path, 'h632') : null;
// Sort by popularity/vote
movieCredits = [...movieCredits].sort((a, b) => (b.vote_average ?? 0) - (a.vote_average ?? 0));
tvCredits = [...tvCredits].sort((a, b) => (b.vote_average ?? 0) - (a.vote_average ?? 0));
---
<DefaultLayout title={person ? `${person.name} — Hexen` : 'Person — Hexen'} description={person?.biography?.slice(0, 160)}>
  {errorMsg ? (
    <div class="container-content py-16 text-center">
      <p class="text-red-400">{errorMsg}</p>
      <a href="/search" class="mt-4 inline-block btn-ghost">← Search</a>
    </div>
  ) : person ? (
    <div class="container-content py-8">
      <div class="flex flex-col gap-6 sm:flex-row">
        <div class="flex-shrink-0">
          <div class="w-40 overflow-hidden rounded-xl shadow-2xl sm:w-52">
            {profile ? (
              <img src={profile} alt={person.name} class="w-full" />
            ) : (
              <div class="flex aspect-[2/3] items-center justify-center bg-base-elevated text-4xl text-ink-secondary">{person.name.charAt(0)}</div>
            )}
          </div>
        </div>

        <div class="flex-1">
          <h1 class="text-3xl font-extrabold sm:text-4xl">{person.name}</h1>
          {person.known_for_department && (
            <p class="mt-1 text-ink-secondary">Known for {person.known_for_department}</p>
          )}
          <div class="mt-3 flex flex-wrap gap-4 text-sm text-ink-secondary">
            {person.birthday && <span>Born: {formatDate(person.birthday)}</span>}
            {person.deathday && <span>Died: {formatDate(person.deathday)}</span>}
            {person.place_of_birth && <span>From: {person.place_of_birth}</span>}
          </div>

          {person.biography && (
            <section class="mt-6">
              <h2 class="mb-2 text-lg font-bold">Biography</h2>
              <p class="whitespace-pre-line leading-relaxed text-ink-secondary">{person.biography}</p>
            </section>
          )}
        </div>
      </div>

      {movieCredits.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-xl font-bold">🎬 Movie Credits ({movieCredits.length})</h2>
          <div class="no-scrollbar flex gap-4 overflow-x-auto pb-2">
            {movieCredits.slice(0, 18).map((m) => (
              <div class="w-36 flex-shrink-0">
                <PosterCard item={m as any} type="movie" />
                {m.character && <p class="mt-1 truncate text-center text-xs text-ink-secondary">as {m.character}</p>}
              </div>
            ))}
          </div>
        </section>
      )}

      {tvCredits.length > 0 && (
        <section class="mt-10">
          <h2 class="mb-3 text-xl font-bold">📺 TV Credits ({tvCredits.length})</h2>
          <div class="no-scrollbar flex gap-4 overflow-x-auto pb-2">
            {tvCredits.slice(0, 18).map((t) => (
              <div class="w-36 flex-shrink-0">
                <PosterCard item={t as any} type="tv" />
                {t.character && <p class="mt-1 truncate text-center text-xs text-ink-secondary">as {t.character}</p>}
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  ) : null}
</DefaultLayout>
