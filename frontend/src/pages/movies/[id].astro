---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import CastList from '@/components/details/CastList.astro';
import VideoModal from '@/components/details/VideoModal.svelte';
import ReviewCard from '@/components/details/ReviewCard.astro';
import PosterCard from '@/components/media/PosterCard.astro';
import { api, ApiError } from '@/lib/api/client';
import type { Movie, CastMember, Video, Review } from '@/lib/api/types';
import { backdropUrl, posterUrl } from '@/lib/utils/image';
import { formatRuntime, formatCurrency, formatDate, formatRating } from '@/lib/utils/format';

const { id } = Astro.params;
if (!id || isNaN(Number(id))) {
  return Astro.redirect('/404');
}

let movie: Movie | null = null;
let cast: CastMember[] = [];
let videos: Video[] = [];
let similar: Movie[] = [];
let recommendations: Movie[] = [];
let reviews: Review[] = [];
let errorMsg = '';

try {
  const [m, c, v, s, r, rev] = await Promise.all([
    api.movie(Number(id)),
    api.movieCredits(Number(id)).then(r => r.cast ?? []).catch(() => []),
    api.movieVideos(Number(id)).then(r => r.videos ?? []).catch(() => []),
    api.movieSimilar(Number(id), 1).then(r => r.results ?? []).catch(() => []),
    api.movieRecommendations(Number(id), 1).then(r => r.results ?? []).catch(() => []),
    api.movieReviews(Number(id)).then(r => r.reviews ?? []).catch(() => []),
  ]);
  movie = m; cast = c; videos = v; similar = s; recommendations = r; reviews = rev;
} catch (e) {
  errorMsg = e instanceof ApiError ? e.message : 'Failed to load movie';
}

const backdrop = movie ? backdropUrl(movie.backdrop_path, 'w1280') : null;
const poster = movie ? posterUrl(movie.poster_path, 'w500') : null;
---
<DefaultLayout title={movie ? `${movie.title} — Hexen` : 'Movie — Hexen'} description={movie?.overview}>
  {errorMsg ? (
    <div class="container-content py-16 text-center">
      <p class="text-red-400">{errorMsg}</p>
      <a href="/movies" class="mt-4 inline-block btn-ghost">← Back to Movies</a>
    </div>
  ) : movie ? (
    <>
      {/* Backdrop hero */}
      <section class="relative h-[50vh] min-h-[360px] w-full overflow-hidden">
        {backdrop ? (
          <img src={backdrop} alt="" class="absolute inset-0 h-full w-full object-cover" />
        ) : (
          <div class="absolute inset-0 bg-base-elevated"></div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-base via-base/70 to-base/30"></div>
      </section>

      <div class="container-content -mt-32 relative pb-12">
        <div class="flex flex-col gap-6 sm:flex-row">
          {/* Poster */}
          <div class="flex-shrink-0">
            <div class="w-40 overflow-hidden rounded-xl shadow-2xl sm:w-52">
              {poster ? (
                <img src={poster} alt={movie.title} class="w-full" />
              ) : (
                <div class="flex aspect-[2/3] items-center justify-center bg-base-elevated text-ink-secondary">No image</div>
              )}
            </div>
          </div>

          {/* Title + meta */}
          <div class="flex-1 pt-2 sm:pt-32">
            <h1 class="text-3xl font-extrabold sm:text-4xl">{movie.title}</h1>
            {movie.tagline && <p class="mt-1 text-lg italic text-ink-secondary">{movie.tagline}</p>}
            <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-ink-secondary">
              {movie.vote_average > 0 && <span class="text-yellow-400">★ {formatRating(movie.vote_average)}</span>}
              {movie.release_date && <span>{formatDate(movie.release_date)}</span>}
              {movie.runtime ? <span>{formatRuntime(movie.runtime)}</span> : null}
              {movie.status && <span class="chip">{movie.status}</span>}
            </div>

            {movie.genres && movie.genres.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {movie.genres.map(g => <a href={`/discover?with_genres=${g.id}&type=movie`} class="chip hover:chip-active">{g.name}</a>)}
              </div>
            )}

            <div class="mt-6 flex gap-3">
              <a href={`/watch/movie/${movie.id}`} class="btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                Watch Now
              </a>
              {movie.imdb_id && (
                <a href={`https://www.imdb.com/title/${movie.imdb_id}`} target="_blank" rel="noopener" class="btn-ghost">IMDb</a>
              )}
            </div>
          </div>
        </div>

        {/* Overview */}
        {movie.overview && (
          <section class="mt-8">
            <h2 class="mb-2 text-xl font-bold">Overview</h2>
            <p class="leading-relaxed text-ink-secondary">{movie.overview}</p>
          </section>
        )}

        {/* Meta details */}
        <section class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
          {movie.budget !== undefined && (
            <div><p class="text-xs text-ink-secondary">Budget</p><p class="font-medium">{formatCurrency(movie.budget)}</p></div>
          )}
          {movie.revenue !== undefined && (
            <div><p class="text-xs text-ink-secondary">Revenue</p><p class="font-medium">{formatCurrency(movie.revenue)}</p></div>
          )}
          {movie.original_language && (
            <div><p class="text-xs text-ink-secondary">Language</p><p class="font-medium uppercase">{movie.original_language}</p></div>
          )}
          {movie.production_companies && movie.production_companies.length > 0 && (
            <div><p class="text-xs text-ink-secondary">Studios</p><p class="font-medium">{movie.production_companies.map(c => c.name).join(', ')}</p></div>
          )}
        </section>

        {/* Cast */}
        <CastList cast={cast} />

        {/* Videos */}
        <VideoModal client:visible videos={videos} />

        {/* Recommendations */}
        {recommendations.length > 0 && (
          <section class="mt-8">
            <h2 class="mb-3 text-xl font-bold">Recommended</h2>
            <div class="no-scrollbar flex gap-4 overflow-x-auto pb-2">
              {recommendations.slice(0, 12).map((m) => (
                <div class="w-36 flex-shrink-0"><PosterCard item={m} type="movie" /></div>
              ))}
            </div>
          </section>
        )}

        {/* Similar */}
        {similar.length > 0 && (
          <section class="mt-8">
            <h2 class="mb-3 text-xl font-bold">More Like This</h2>
            <div class="no-scrollbar flex gap-4 overflow-x-auto pb-2">
              {similar.slice(0, 12).map((m) => (
                <div class="w-36 flex-shrink-0"><PosterCard item={m} type="movie" /></div>
              ))}
            </div>
          </section>
        )}

        {/* Reviews */}
        <ReviewCard reviews={reviews} />
      </div>
    </>
  ) : null}
</DefaultLayout>
