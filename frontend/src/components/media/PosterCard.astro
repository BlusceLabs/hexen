---
import type { Movie, TvShow, SearchResult } from '@/lib/api/types';
import { posterUrl } from '@/lib/utils/image';
import { formatYear, formatRating } from '@/lib/utils/format';

interface Props {
  item: Movie | TvShow | SearchResult;
  type?: 'movie' | 'tv' | 'person';
}

const { item, type } = Astro.props;
const mediaType = type ?? ('media_type' in item ? item.media_type : 'movie');
const title = 'title' in item ? item.title : (item as any).name ?? 'Untitled';
const date = 'release_date' in item ? item.release_date : (item as any).first_air_date;
const poster = posterUrl(item.poster_path, 'w342');
const href = mediaType === 'tv' ? `/tv/${item.id}` : mediaType === 'person' ? `/person/${item.id}` : `/movies/${item.id}`;
const rating = 'vote_average' in item ? item.vote_average : 0;
---
<a href={href} class="group block overflow-hidden rounded-lg bg-base-surface shadow-md transition-transform duration-200 hover:scale-105 hover:shadow-xl hover:shadow-accent/10">
  <div class="relative aspect-[2/3] overflow-hidden bg-base-elevated">
    {poster ? (
      <img
        src={poster}
        alt={title}
        class="h-full w-full object-cover transition-opacity duration-300 group-hover:opacity-90"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-ink-secondary text-xs p-2 text-center">
        {title}
      </div>
    )}
    {rating > 0 && (
      <span class="absolute bottom-2 left-2 rounded bg-black/80 px-1.5 py-0.5 text-xs font-semibold text-yellow-400">
        ★ {formatRating(rating)}
      </span>
    )}
  </div>
  <div class="p-2.5">
    <p class="truncate text-sm font-medium text-ink-primary">{title}</p>
    {date && <p class="text-xs text-ink-secondary">{formatYear(date)}</p>}
  </div>
</a>
