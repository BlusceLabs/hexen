---
interface Props {
  message?: string;
  title?: string;
  onRetry?: string;
}

const { 
  message = 'Something went wrong. Please try again.', 
  title = 'Error',
  onRetry 
} = Astro.props;
---

<div 
  role="alert" 
  aria-live="assertive"
  class="rounded-lg border-2 border-red-600/20 bg-red-600/10 p-6 text-center"
>
  <div class="mb-3 flex justify-center">
    <div class="rounded-full bg-red-600/20 p-3">
      <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
    </div>
  </div>
  <h3 class="mb-2 text-lg font-semibold text-red-600">{title}</h3>
  <p class="mb-4 text-sm text-ink-secondary">{message}</p>
  {onRetry && (
    <button
      onclick={onRetry}
      class="btn-primary"
      type="button"
    >
      Try Again
    </button>
  )}
</div>
