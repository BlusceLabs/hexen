---
import type { Review } from '@/lib/api/types';
import { formatDate } from '@/lib/utils/format';

interface Props {
  reviews: Review[];
}
const { reviews } = Astro.props;
const limited = reviews.slice(0, 5);
---
{limited.length > 0 && (
  <section class="mt-8">
    <h2 class="mb-3 text-xl font-bold">Reviews</h2>
    <div class="space-y-4">
      {limited.map((r) => (
        <article class="card-surface p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-base-elevated text-sm font-semibold">{r.author.charAt(0).toUpperCase()}</div>
              <span class="font-medium">{r.author}</span>
            </div>
            {r.author_details?.rating && (
              <span class="chip">★ {r.author_details.rating}/10</span>
            )}
          </div>
          <p class="mt-3 text-sm text-ink-secondary line-clamp-4">{r.content}</p>
          <p class="mt-2 text-xs text-ink-secondary">{formatDate(r.created_at)}</p>
        </article>
      ))}
    </div>
  </section>
)}
