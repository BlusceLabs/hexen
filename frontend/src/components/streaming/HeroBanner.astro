---
import type { SearchResult } from '@/lib/api/types';
import { backdropUrl } from '@/lib/utils/image';

interface Props {
  featured: SearchResult;
}

const { featured } = Astro.props;

const title = featured.title ?? featured.name ?? 'Featured';
const overview = featured.overview ?? 'No description available.';
const backdropImage = backdropUrl(featured.backdrop_path, 'w1280');
const detailHref = featured.media_type === 'tv' ? `/tv/${featured.id}` : `/movies/${featured.id}`;
const watchHref = featured.media_type === 'tv' ? `/watch/tv/${featured.id}` : `/watch/movie/${featured.id}`;
---

<section class="relative h-[85vh] min-h-[600px] w-full overflow-hidden">
  <!-- Background Image -->
  {#if backdropImage}
    <div class="absolute inset-0">
      <img
        src={backdropImage}
        alt=""
        class="h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-base via-base/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-base/80 via-base/40 to-transparent"></div>
    </div>
  {:else}
    <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-base"></div>
  {/if}

  <!-- Content -->
  <div class="container-content relative flex h-full items-end pb-20 md:items-center md:pb-0">
    <div class="max-w-2xl space-y-6">
      <!-- Title -->
      <h1 class="text-4xl font-black tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl drop-shadow-2xl">
        {title}
      </h1>

      <!-- Meta Info -->
      <div class="flex flex-wrap items-center gap-4 text-sm font-medium text-white/90">
        {#if featured.vote_average && featured.vote_average > 0}
          <div class="flex items-center gap-1">
            <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <span>{featured.vote_average.toFixed(1)}</span>
          </div>
        {/if}
        
        {#if featured.release_date || featured.first_air_date}
          <span>{new Date(featured.release_date ?? featured.first_air_date!).getFullYear()}</span>
        {/if}
        
        <span class="rounded bg-white/20 px-2 py-0.5 text-xs uppercase backdrop-blur">
          {featured.media_type === 'tv' ? 'TV Series' : 'Movie'}
        </span>
      </div>

      <!-- Overview -->
      <p class="text-base text-white/90 line-clamp-3 md:text-lg drop-shadow-lg">
        {overview}
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-wrap gap-3">
        <a
          href={watchHref}
          class="group inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 font-bold text-base shadow-xl transition-all hover:scale-105 hover:bg-white/90 focus:outline-none focus:ring-4 focus:ring-white/50"
        >
          <svg class="h-6 w-6 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 20 20">
            <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
          </svg>
          Play Now
        </a>
        
        <a
          href={detailHref}
          class="inline-flex items-center gap-2 rounded-lg bg-white/20 px-6 py-3 font-bold text-white backdrop-blur transition-all hover:bg-white/30 focus:outline-none focus:ring-4 focus:ring-white/50"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          More Info
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-8 w-8 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
