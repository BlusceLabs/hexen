# Hexen API Configuration

# Moviebox API Host (optional - defaults to h5-api.aoneroom.com)
MOVIEBOX_API_HOST_V2=h5-api.aoneroom.com

# Moviebox Secret Keys (optional - uses defaults if not set)
# MOVIEBOX_SECRET_KEY_DEFAULT=your_secret_key_here
# MOVIEBOX_SECRET_KEY_ALT=your_alt_secret_key_here

# Moviebox Auth Token (optional)
# MOVIEBOX_AUTH_TOKEN=your_auth_token_here

# Backend Server Configuration
HOST=0.0.0.0
PORT=8000

# Frontend Configuration
PUBLIC_API_BASE=http://localhost:8000
